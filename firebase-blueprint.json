{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile data, credits, and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "sub-admin", "super-admin"] },
        "credits": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "credits"]
    },
    "Story": {
      "title": "CineAura Story",
      "description": "Narrative scripts and metadata generated by CineAura.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "topic": { "type": "string" },
        "script": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "processing", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "script", "createdAt"]
    },
    "Audiobook": {
      "title": "Audiobook Content",
      "description": "Generated audio files and narration metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "storyId": { "type": "string" },
        "audioUrl": { "type": "string" },
        "duration": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "audioUrl", "createdAt"]
    },
    "Design": {
      "title": "ThumbAura Design",
      "description": "Thumbnails and images generated by ThumbAura.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "prompt": { "type": "string" },
        "imageUrl": { "type": "string" },
        "aspectRatio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "prompt", "imageUrl", "createdAt"]
    },
    "Activity": {
      "title": "User Activity Log",
      "description": "Logging for audit and cleanup policies.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "createdAt"]
    },
    "ApiKey": {
      "title": "API Key Pool",
      "description": "Master keys for rotation (Admin only).",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "provider": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "rate-limited", "error"] },
        "addedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["key", "status", "createdAt"]
    },
    "Project": {
      "title": "Auurio Project",
      "description": "Unified project state for resumable generations.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "topic": { "type": "string" },
        "type": { "type": "string", "enum": ["cine", "reel", "thumb"] },
        "status": { "type": "string", "enum": ["draft", "processing", "completed"] },
        "progress": { "type": "number" },
        "activeStep": { "type": "string" },
        "scenes": { "type": "array" },
        "theme": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "type", "status", "createdAt"]
    },
    "Package": {
      "title": "Pricing Package",
      "description": "Subscription or credit packages available for purchase.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "credits": { "type": "number" },
        "price": { "type": "number" },
        "features": { "type": "array" },
        "popular": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "credits", "price"]
    },
    "Coupon": {
      "title": "Discount Coupon",
      "description": "Codes provided to users for discounts on packages.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["fixed", "percent"] },
        "value": { "type": "number" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "usageLimit": { "type": "number" },
        "usageCount": { "type": "number" }
      },
      "required": ["code", "discountType", "value"]
    },
    "Payment": {
      "title": "Payment Record",
      "description": "Tracking user payments and manual verifications.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "packageId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string", "enum": ["bkash", "nagad"] },
        "transactionId": { "type": "string" },
        "senderNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "packageId", "amount", "method", "transactionId", "senderNumber", "status"]
    },
    "Settings": {
      "title": "Global Settings",
      "description": "Admin configuration like payment numbers and profit margins.",
      "type": "object",
      "properties": {
        "bkashNumber": { "type": "string" },
        "nagadNumber": { "type": "string" },
        "minProfitMargin": { "type": "number" },
        "budgetLimit": { "type": "number" },
        "totalSpent": { "type": "number" }
      }
    },
    "UsageLog": {
      "title": "AI Usage Log",
      "description": "Tracking token usage and cost for every AI generation call.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "feature": { "type": "string" },
        "modelId": { "type": "string" },
        "inputTokens": { "type": "number" },
        "outputTokens": { "type": "number" },
        "cost": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "feature", "modelId", "cost", "createdAt"]
    }
  },
  "firestore": {
    "/usage_logs/{logId}": {
      "schema": "UsageLog",
      "description": "Detailed AI consumption and cost tracking."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and settings."
    },
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "CineAura storytelling scripts."
    },
    "/audiobooks/{audioId}": {
      "schema": "Audiobook",
      "description": "Generated audio files."
    },
    "/designs/{designId}": {
      "schema": "Design",
      "description": "Generated thumbnails and assets."
    },
    "/activity/{activityId}": {
      "schema": "Activity",
      "description": "System activity logs."
    },
    "/api_keys/{keyId}": {
      "schema": "ApiKey",
      "description": "Master API keys for rotation."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "User projects with state persistence."
    },
    "/packages/{packageId}": {
      "schema": "Package",
      "description": "Available credit packages."
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Active discount codes."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Transaction logs and verification queue."
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Admin global configuration."
    }
  }
}
