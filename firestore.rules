rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin' ||
          (request.auth.token.email == "disat386@gmail.com"));
    }

    function isAdmin() {
      return isSuperAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // 1. USERS COLLECTION
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      
      // Extremely permissive update: users can update their own document. 
      // (We trust the client for now to fix the blocking issue)
      allow update: if isOwner(userId) || isAdmin();
                       
      // Allow any subcollections under the user document
      match /{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // 2. PROTECTED SYSTEM COLLECTIONS
    match /api_keys/{keyId} {
      allow read: if true; 
      allow write: if isSuperAdmin();
    }

    match /gemini_keys/{keyId} {
      allow read: if true; 
      allow write: if isSuperAdmin();
    }

    match /packages/{packageId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /reframe_settings/{id} { // Explicitly allow Reframe settings
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /coupons/{code} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /transactions/{txId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /purchase_history/{id} {
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow create: if true; // anyone can submit feedback
      allow read, update, delete: if isAdmin(); // only admins can read it
    }

    // 3. ALL OTHER COLLECTIONS (Reframe, Audiobook, etc.)
    match /{collection}/{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
